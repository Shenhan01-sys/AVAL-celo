# AgentBeacon heartbeat loop config
NETWORK=alfajores                 # alfajores (testnet) | celo (mainnet, real funds)
BEACON_ADDRESS=                   # deployed AgentBeacon address
AGENT_PRIVATE_KEY=                # the agent key (authorized via setAgent / deploy)
INTERVAL_MS=180000                # 3 minutes between beats
MAX_BEATS=0                       # 0 = run forever
MIN_BALANCE_WEI=2000000000000000  # stop if balance below 0.002 native

# Ship-journal (commit drip) — journal.mjs
JOURNAL_INTERVAL_MS=300000        # 5 minutes between journal commits
JOURNAL_MAX=0                     # 0 = run forever
