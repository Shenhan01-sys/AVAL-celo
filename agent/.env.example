# --- x402 (Casper-native, hosted facilitator) ---
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_CHAIN_ID=casper:casper-test
X402_ASSET_PACKAGE=hash-<aUSD MockUsd package hash>
X402_ASSET_NAME=aUSD
X402_PAY_TO=<Aval treasury account hash>
X402_PRICE=0.50                 # price per verification, in aUSD
X402_ACCESS_TOKEN=<CSPR.cloud access token (buildathon sponsored)>

# --- Casper contracts (testnet package hashes) ---
FUNDING_POOL_HASH=hash-...
FINANCING_TOKEN_HASH=hash-...
REPUTATION_ORACLE_HASH=hash-...
INVOICE_REGISTRY_HASH=hash-...

# --- Verifier agent identity (holds the aiVerifier role) ---
AGENT_SECRET_KEY_PATH=./keys/agent_secret_key.pem
CASPER_NODE_RPC=https://node.testnet.cspr.cloud

# --- Modes ---
CHAIN_MOCK_MODE=true            # true = simulate on-chain calls for demo
AI_MOCK_MODE=true               # true = deterministic risk model, no API spend
# ANTHROPIC_API_KEY=
